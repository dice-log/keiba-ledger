# Keiba Ledger — 環境変数サンプル
# コピー: copy .env.example .env
# .env を編集して値を設定してください

# ローカルPostgreSQL
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=keiba
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=your_password

# Supabase（Phase 1後半で使用）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JV-Link（UNKNOWNで認証ダイアログ、またはID指定）
JVLINK_SOFTWARE_ID=your_software_id
JVLINK_USER_ID=your_user_id
